# EG Construction ERP — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored. Never commit real values.
# Set these same variables in your Vercel dashboard for production.

VITE_SHEETS_PROXY_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_SHEETS_PROXY_SECRET=your-secret-here

VITE_SHEET_ERP=your-erp-template-sheet-id
VITE_SHEET_SECRETS=your-usersecrets-sheet-id
VITE_SHEET_EMPLOYEES=your-employee-register-sheet-id
VITE_SHEET_ACCOUNTS=your-account-view-sheet-id
VITE_SHEET_MASTER=your-master-sheet-id
VITE_SHEET_PURCHASE=your-purchase-sheet-id
VITE_SHEET_STORES=your-stores-sheet-id
